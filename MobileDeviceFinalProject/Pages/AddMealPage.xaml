<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MobileDeviceFinalProject.Pages.AddMealPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:pageModels="clr-namespace:MobileDeviceFinalProject.PageModels"
    xmlns:models="clr-namespace:MobileDeviceFinalProject.Models"
    x:DataType="pageModels:AddMealPageModel"
    Title="Add Meal">

    <ContentPage.Resources>
        <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Cancel" Command="{Binding CancelCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Spacing="12" Padding="{StaticResource LayoutPadding}">

            <!-- API Search -->
            <Label Text="Search Food (USDA FoodData Central)" Style="{StaticResource Title2}" FontSize="18" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Entry
                    Grid.Column="0"
                    Placeholder="e.g. chicken breast 200g"
                    Text="{Binding SearchQuery}"
                    ReturnCommand="{Binding SearchCommand}" />
                <Button
                    Grid.Column="1"
                    Text="Search"
                    Command="{Binding SearchCommand}"
                    IsEnabled="{Binding IsSearching, Converter={StaticResource InvertedBoolConverter}}" />
            </Grid>

            <ActivityIndicator IsVisible="{Binding IsSearching}" IsRunning="{Binding IsSearching}" HorizontalOptions="Center" />

            <!-- Search Results -->
            <CollectionView
                ItemsSource="{Binding SearchResults}"
                IsVisible="{Binding IsSearching, Converter={StaticResource InvertedBoolConverter}}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:NutritionResult">
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,6">
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{Binding FoodName}" FontAttributes="Bold" FontSize="15" />
                                    <Label Text="{Binding DisplayText}" FontSize="12" />
                                </VerticalStackLayout>
                                <Button
                                    Grid.Column="1"
                                    Text="Select"
                                    FontSize="13"
                                    VerticalOptions="Center"
                                    Command="{Binding SelectResultCommand, Source={RelativeSource AncestorType={x:Type pageModels:AddMealPageModel}}, x:DataType=pageModels:AddMealPageModel}"
                                    CommandParameter="{Binding .}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Confirm Selected API Result -->
            <Border Style="{StaticResource CardStyle}" IsVisible="{Binding SelectedResult, Converter={toolkit:IsNotNullConverter}}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Confirm Entry" FontAttributes="Bold" FontSize="16" />
                    <Label Text="{Binding SelectedResult.DisplayText}" FontSize="14" />
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <Button
                            Grid.Column="1"
                            Text="📷 Photo"
                            Command="{Binding TakePhotoCommand}"
                            BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}"
                            FontSize="14" />
                        <Button
                            Grid.Column="2"
                            Text="✅ Save"
                            Command="{Binding ConfirmApiEntryCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
                    </Grid>
                    <Label
                        Text="{Binding PhotoPath, StringFormat='📸 {0}'}"
                        FontSize="12"
                        IsVisible="{Binding PhotoPath, Converter={toolkit:IsNotNullConverter}}" />
                </VerticalStackLayout>
            </Border>

            <BoxView HeightRequest="1" Margin="0,8" />

            <!-- Manual Entry Toggle -->
            <Button
                Text="Enter Manually (Offline)"
                Command="{Binding ToggleManualEntryCommand}"
                BackgroundColor="Transparent"
                TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />

            <!-- Manual Entry Form -->
            <VerticalStackLayout Spacing="10" IsVisible="{Binding ShowManualEntry}">
                <Label Text="Manual Entry" Style="{StaticResource Title2}" FontSize="18" />
                <Entry Placeholder="Food name *" Text="{Binding ManualFoodName}" />
                <Entry Placeholder="Calories (kcal) *" Text="{Binding ManualCalories}" Keyboard="Numeric" />
                <Entry Placeholder="Protein (g)" Text="{Binding ManualProtein}" Keyboard="Numeric" />
                <Entry Placeholder="Carbs (g)" Text="{Binding ManualCarbs}" Keyboard="Numeric" />
                <Entry Placeholder="Fat (g)" Text="{Binding ManualFat}" Keyboard="Numeric" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Button
                        Grid.Column="0"
                        Text="📷 Take Photo"
                        Command="{Binding TakePhotoCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    <Button
                        Grid.Column="1"
                        Text="Save"
                        Command="{Binding SaveManualEntryCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
                </Grid>
                <Label
                    Text="{Binding PhotoPath, StringFormat='📸 {0}'}"
                    FontSize="12"
                    IsVisible="{Binding PhotoPath, Converter={toolkit:IsNotNullConverter}}" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
