<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MobileDeviceFinalProject.Pages.AddVitaminPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:pageModels="clr-namespace:MobileDeviceFinalProject.PageModels"
    x:DataType="pageModels:AddVitaminPageModel"
    Title="Add Vitamin">

    <ContentPage.Resources>
        <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Cancel" Command="{Binding CancelCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Spacing="12" Padding="{StaticResource LayoutPadding}">

            <Label Text="Vitamin / Supplement Name *" FontAttributes="Bold" />
            <Entry Placeholder="e.g. Vitamin D" Text="{Binding Name}" />

            <Label Text="Dosage" FontAttributes="Bold" />
            <Entry Placeholder="e.g. 1000 IU" Text="{Binding Dosage}" />

            <Label Text="Benefits" FontAttributes="Bold" />
            <Editor Placeholder="e.g. Supports bone health and immune function" Text="{Binding Benefits}" HeightRequest="80" />

            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0" Text="Take daily?" VerticalOptions="Center" FontAttributes="Bold" />
                <Switch Grid.Column="1" IsToggled="{Binding IsDaily}" VerticalOptions="Center" />
            </Grid>

            <Button
                Text="Save Vitamin"
                Command="{Binding SaveCommand}"
                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                Margin="0,8,0,0" />

            <ActivityIndicator IsVisible="{Binding IsBusy}" IsRunning="{Binding IsBusy}" HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
