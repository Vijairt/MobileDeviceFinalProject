<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MobileDeviceFinalProject.Pages.WorkoutPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:pageModels="clr-namespace:MobileDeviceFinalProject.PageModels"
    xmlns:models="clr-namespace:MobileDeviceFinalProject.Models"
    x:DataType="pageModels:WorkoutPageModel"
    Title="Workouts">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
            EventName="Appearing"
            Command="{Binding AppearingCommand}" />
    </ContentPage.Behaviors>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Add" Command="{Binding AddWorkoutCommand}" IconImageSource="{StaticResource IconAdd}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Weekly summary -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="{StaticResource LayoutPadding}">
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="4">
                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                    <Label Text="{Binding WeeklyWorkouts.Count}" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" />
                    <Label Text="Sessions" FontSize="12" HorizontalOptions="Center" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                    <Label Text="{Binding TotalMinutesThisWeek}" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" />
                    <Label Text="Minutes" FontSize="12" HorizontalOptions="Center" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                    <Label Text="{Binding TotalMilesThisWeek, StringFormat='{0:F1}'}" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" />
                    <Label Text="Miles" FontSize="12" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- Progression tip -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="{StaticResource LayoutPadding}">
            <Label Text="{Binding ProgressionTip}" FontSize="14" />
        </Border>

        <!-- Workout list -->
        <CollectionView
            Grid.Row="2"
            ItemsSource="{Binding WeeklyWorkouts}"
            Margin="{StaticResource LayoutPadding}">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8" Margin="0,30">
                    <Label Text="No workouts logged this week." HorizontalOptions="Center" />
                    <Label Text="Tap + to log a session." FontSize="13" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:WorkoutEntry">
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="{Binding ExerciseType}" FontAttributes="Bold" FontSize="16" />
                                <Label Text="{Binding DurationMinutes, StringFormat='{0} min'}" FontSize="14" />
                                <Label Text="{Binding DistanceMiles, StringFormat='{0:F2} miles'}"
                                       FontSize="13"
                                       IsVisible="{Binding DistanceMiles, Converter={toolkit:IsNotNullConverter}}" />
                                <Label FontSize="13"
                                       IsVisible="{Binding Sets, Converter={toolkit:IsNotNullConverter}}">
                                    <Label.Text>
                                        <MultiBinding StringFormat="{}{0} sets × {1} reps">
                                            <Binding Path="Sets" />
                                            <Binding Path="Reps" />
                                        </MultiBinding>
                                    </Label.Text>
                                </Label>
                                <Label Text="{Binding Notes}" FontSize="12"
                                       IsVisible="{Binding Notes, Converter={toolkit:IsNotNullConverter}}" />
                                <Label Text="{Binding LoggedAt, StringFormat='{0:ddd, MMM d}'}" FontSize="11" />
                            </VerticalStackLayout>
                            <ImageButton
                                Grid.Column="1"
                                Source="{StaticResource IconDelete}"
                                HeightRequest="36"
                                WidthRequest="36"
                                Aspect="Center"
                                VerticalOptions="Center"
                                Command="{Binding DeleteWorkoutCommand, Source={RelativeSource AncestorType={x:Type pageModels:WorkoutPageModel}}, x:DataType=pageModels:WorkoutPageModel}"
                                CommandParameter="{Binding .}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
