<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MobileDeviceFinalProject.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:pageModels="clr-namespace:MobileDeviceFinalProject.PageModels"
    x:DataType="pageModels:DashboardPageModel"
    Title="FitTrack Pro">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
            EventName="Appearing"
            Command="{Binding AppearingCommand}" />
    </ContentPage.Behaviors>

    <ScrollView>
        <VerticalStackLayout Spacing="12" Padding="{StaticResource LayoutPadding}">

            <Label
                Text="{Binding Today}"
                Style="{StaticResource Title2}" />

            <!-- Calorie Summary Card -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="🍽️ Today's Nutrition" Style="{StaticResource Title2}" FontSize="18" />
                    <Label
                        Text="{Binding TotalCaloriesToday, StringFormat='{0:F0} kcal consumed'}"
                        FontSize="36"
                        FontAttributes="Bold"
                        HorizontalOptions="Center" />
                    <Label
                        Text="{Binding CalorieStatus}"
                        HorizontalOptions="Center"
                        FontSize="14" />
                    <BoxView HeightRequest="1" Margin="0,4" />
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                            <Label Text="{Binding TotalProteinToday, StringFormat='{0:F0}g'}" FontAttributes="Bold" HorizontalOptions="Center" FontSize="18" />
                            <Label Text="Protein" FontSize="12" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                            <Label Text="{Binding TotalCarbsToday, StringFormat='{0:F0}g'}" FontAttributes="Bold" HorizontalOptions="Center" FontSize="18" />
                            <Label Text="Carbs" FontSize="12" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                            <Label Text="{Binding TotalFatToday, StringFormat='{0:F0}g'}" FontAttributes="Bold" HorizontalOptions="Center" FontSize="18" />
                            <Label Text="Fat" FontSize="12" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Weekly Workouts Card -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="💪 This Week's Workouts" Style="{StaticResource Title2}" FontSize="18" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                            <Label Text="{Binding WorkoutsThisWeek}" FontSize="36" FontAttributes="Bold" HorizontalOptions="Center" />
                            <Label Text="Sessions" FontSize="12" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                            <Label Text="{Binding TotalWorkoutMinutesThisWeek}" FontSize="36" FontAttributes="Bold" HorizontalOptions="Center" />
                            <Label Text="Minutes" FontSize="12" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Vitamin Streaks Card -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="💊 Vitamin Streaks" Style="{StaticResource Title2}" FontSize="18" />
                    <Label Text="{Binding VitaminStreakSummary}" FontSize="14" />
                </VerticalStackLayout>
            </Border>

            <ActivityIndicator
                IsVisible="{Binding IsBusy}"
                IsRunning="{Binding IsBusy}"
                HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
